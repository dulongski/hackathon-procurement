FROM node:20-alpine

WORKDIR /app

# Copy frontend source
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install

COPY frontend/ .

# Build
ENV NEXT_PUBLIC_API_BASE=/api
RUN npm run build

# Run in production mode (not standalone — simpler)
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

EXPOSE 3000

CMD ["npm", "start"]
